
// ============================================================
// Condensed DBML (v3)
// Invoice + Payable + PaymentRun + RunPayables
// + Payment + PaymentAllocation (NORMALIZED)
// + Artifacts + Register
// ============================================================

// -------------------------
// Enums
// -------------------------

Enum ap_payable_status {
  OPEN
  CLOSED
  VOID
}

Enum ap_payment_run_payable_status {
  DRAFT
  INCLUDED
  EXCLUDED
  NEEDS_REVIEW
  LOCKED
  EXECUTED
  SKIPPED
}

Enum ap_payment_run_status {
  DRAFT
  SUBMITTED
  READY_FOR_REVIEW
  PENDING_APPROVAL
  APPROVED
  ARTIFACT_PENDING
  ARTIFACT_READY
  COMPLETED
  REJECTED
  FAILED
  CANCELLED
}

Enum ap_payment_method {
  CHECK
  ACH
  WIRE
  WARRANT
}

Enum ap_payment_artifact_type {
  CHECK
  ACH
  WIRE
  POSITIVE_PAY
  REMITTANCE
}

Enum ap_payment_artifact_status {
  CREATED
  GENERATED
  TRANSMITTED
  ACCEPTED
  REJECTED
  REISSUED
  FAILED
}

Enum ap_payment_status {
  ISSUED
  VOIDED
  REVERSED
  SETTLED
  FAILED
}

Enum invoice_source {
  MANUAL
  IMPORT
  INTEGRATION
  OTHER
}

// ============================================================
// Invoice Header
// ============================================================

Table ap_invoice_header {
  id uuid [pk, not null]
  entity_id uuid [not null]

  invoice_header_id bigint [not null, unique]
  ap_vendor_id int [not null]
  currency varchar(8) [not null]
  invoice_amount decimal(18,4) [not null]

  invoice_due_date date
  due_date_override date

  invoice_type varchar(64) [not null]
  invoice_status varchar(64) [not null]
  invoice_source invoice_source [not null]

  has_errors boolean [not null, default: false]

  created_by uuid [not null]
  created_at timestamptz [not null]
  updated_by uuid [not null]
  updated_at timestamptz [not null]
}

// ============================================================
// Payable
// ============================================================

Table ap_payable {
  id uuid [pk, not null]
  entity_id uuid [not null]

  invoice_id uuid [not null]

  payable_type varchar(64) [not null, default: "INVOICE"]
  payable_reference varchar(128)

  currency varchar(8) [not null]

  original_amount decimal(18,4) [not null]
  open_amount decimal(18,4) [not null]

  due_date date
  discount_deadline date
  discount_max decimal(18,4)

  is_on_hold boolean [not null, default: false]

  status ap_payable_status [not null, default: 'OPEN']

  
  created_by uuid [not null]
  created_at timestamptz [not null, default: `now()`]
  updated_by uuid [not null]
  updated_at timestamptz [not null, default: `now()`]
}

// ============================================================
// Payment Run
// ============================================================

Table ap_payment_run {
   id uuid [pk, not null]
  entity_id uuid [not null]

  run_number varchar(20) [not null]
  run_description varchar(200)

  status ap_payment_run_status [not null, default: 'DRAFT']

  // store both "config inputs" and "computed totals snapshot" for review
  config_snapshot jsonb [not null, default: "{}"]

  prepare_job_execution_id bigint
  artifact_job_execution_id bigint
  send_job_execution_id bigint

  submitted_at timestamptz
  submitted_by uuid

  reviewed_at timestamptz
  reviewed_by uuid

  approved_at timestamptz
  approved_by uuid

  issued_at timestamptz
  issued_by uuid

  cancelled_at timestamptz
  cancelled_by uuid
  cancel_reason text

  
  created_by uuid [not null]
  created_at timestamptz [not null, default: `now()`]
  updated_by uuid [not null]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (entity_id, run_number) [unique, name: "uq_ap_payment_run_number"]
    (entity_id, status) [name: "ix_ap_payment_run_status"]
  }
}

// ============================================================
// Payables in Run
// ============================================================

Table ap_payment_run_payable {
  id uuid [pk, not null]
  entity_id uuid [not null]

  payment_run_id uuid [not null]
  payable_id uuid [not null]

  status ap_payment_run_payable_status [not null, default: 'DRAFT']

  

  
  created_by uuid [not null]
  created_at timestamptz [not null, default: `now()`]
  updated_by uuid [not null]
  updated_at timestamptz [not null, default: `now()`]
}

// ============================================================
// Payment (logical payment header)
// ============================================================

Table ap_payment {
  id uuid [pk, not null]
  entity_id uuid [not null]

  payment_run_id uuid [not null]

  payment_number varchar(64) [not null]
  payment_method ap_payment_method
  payable_count int [not null]
  payable_amount decimal(18,4) [not null]
  discount decimal(18,4)
  discounted_amount decimal(18,4) [not null]  

  vendor_id int [not null]
  vendor_name varchar(255)
  vendor_address text

  bank_account_id uuid [not null]
  currency varchar(8) [not null]
  reference varchar(255)  
  
  issue_date date [not null]
  payment_date date [not null]
  issued_at timestamptz

  status ap_payment_status [not null, default: 'ISSUED']

  
  created_by uuid [not null]
  created_at timestamptz [not null, default: `now()`]
  updated_by uuid [not null]
  updated_at timestamptz [not null, default: `now()`]
}

// ============================================================
// NEW: Payment Allocation (Normalized)
// One row per payable covered by a payment
// ============================================================

Table ap_payment_allocation {
  id uuid [pk, not null]
  entity_id uuid [not null]

  payment_id uuid [not null]
  payable_id uuid [not null]
  created_by uuid [not null]
  created_at timestamptz [not null, default: `now()`]
  updated_by uuid [not null]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    payment_id [name: "ix_ap_payment_allocation_payment"]
    payable_id [name: "ix_ap_payment_allocation_payable"]
    (payment_id, payable_id) [unique, name: "uq_ap_payment_payable_once"]
  }
}



// ============================================================
// Relationships
// ============================================================

Ref: ap_payable.invoice_id > ap_invoice_header.id
Ref: ap_payment_run_payable.payment_run_id > ap_payment_run.id
Ref: ap_payment_run_payable.payable_id > ap_payable.id
Ref: ap_payment.payment_run_id > ap_payment_run.id
Ref: ap_payment_allocation.payment_id > ap_payment.id
Ref: ap_payment_allocation.payable_id > ap_payable.id


